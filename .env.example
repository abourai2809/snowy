# Frontend runtime config. Copy to .env.local for local development.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase CLI/project metadata. Keep real values in .env.local or the CLI config,
# never in Git.
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=

# Backend/worker-only secrets. Keep real values in ignored local env files on
# the worker VM/Mac, never in frontend code or Git.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
QUEUEBUSTER_WORKER_ID=
QUEUEBUSTER_POLL_INTERVAL_MS=15000
QUEUEBUSTER_STALE_AFTER_MINUTES=30
QUEUEBUSTER_MAX_ATTEMPTS=3
QUEUEBUSTER_DRY_RUN=1
QUEUEBUSTER_AUDIT_FLAVOUR_CMD=
QUEUEBUSTER_ADD_FLAVOUR_CMD=
QUEUEBUSTER_FIX_FLAVOUR_CMD=
QUEUEBUSTER_CATALOG_PRODUCTS_CHECK_CMD=
QUEUEBUSTER_DOWNLOAD_POS_CSV_CMD=
QUEUEBUSTER_RECONCILE_POS_CMD=
QUEUEBUSTER_ATTENDANCE_ALERT_CHECK_CMD=

# Attendance selfie AI worker. Start with Gemini 2.5 Flash-Lite for simple
# low-volume image checks; switch to gemini-2.5-flash if sample-photo accuracy
# is not good enough.
GEMINI_API_KEY=
ATTENDANCE_SELFIE_MODEL=gemini-2.5-flash-lite
ATTENDANCE_SELFIE_POLL_INTERVAL_MS=30000
ATTENDANCE_SELFIE_RUN_ONCE=0
ATTENDANCE_SELFIE_MAX_CHECKS=
ATTENDANCE_SELFIE_DRY_RUN=1
